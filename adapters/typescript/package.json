{
  "name": "@runeward/sdk",
  "version": "0.1.0",
  "description": "TypeScript client and Vercel AI SDK tools for the runeward governed execution cell.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/Runewardd/runeward"
  },
  "keywords": [
    "ai",
    "agents",
    "sandbox",
    "mcp",
    "governance",
    "vercel-ai-sdk",
    "langchain",
    "strands"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./ai-tools": {
      "types": "./dist/ai-tools.d.ts",
      "import": "./dist/ai-tools.js"
    },
    "./langchain-tools": {
      "types": "./dist/langchain-tools.d.ts",
      "import": "./dist/langchain-tools.js"
    },
    "./strands-tools": {
      "types": "./dist/strands-tools.d.ts",
      "import": "./dist/strands-tools.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0",
    "@strands-agents/sdk": ">=1.0.0",
    "ai": "^7.0.18",
    "zod": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "@strands-agents/sdk": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
